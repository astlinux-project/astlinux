From 0869e72c2cec7cdd2c6a5aff9851179f536dc148 Mon Sep 17 00:00:00 2001
From: "deraadt@openbsd.org" <deraadt@openbsd.org>
Date: Fri, 21 Feb 2025 18:22:41 +0000
Subject: upstream: Also prohibit , (comma) in hostnames, proposed by David

Leadbeater ok djm millert

OpenBSD-Commit-ID: 2837fa31dc6e81976f510f0a259edaa559b20b07

Origin: upstream, https://anongit.mindrot.org/openssh.git/commit/?id=487cf4c18c123b66c1f3f733398cd37e6b2ab6ab
Last-Update: 2026-05-03

Patch-Name: prohibit-comma-in-hostnames.patch
---
 ssh.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/ssh.c b/ssh.c
index 83e73450d..d0891c6d5 100644
--- a/ssh.c
+++ b/ssh.c
@@ -646,7 +646,7 @@ valid_hostname(const char *s)
 	if (*s == '-')
 		return 0;
 	for (i = 0; s[i] != 0; i++) {
-		if (strchr("'`\"$\\;&<>|(){}", s[i]) != NULL ||
+		if (strchr("'`\"$\\;&<>|(){},", s[i]) != NULL ||
 		    isspace((u_char)s[i]) || iscntrl((u_char)s[i]))
 			return 0;
 	}
